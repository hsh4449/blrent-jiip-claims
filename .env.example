# Supabase (blrent-car-system 과 동일 DB 사용)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJhbGc...service_role_key

# IMS Form 로그인 (회사 계정)
IMS_ID=your_ims_id
IMS_PW=your_ims_password

# 솔라피 (Solapi) SMS
SOLAPI_API_KEY=NCSXXXXXXXXXXXXX
SOLAPI_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SOLAPI_FROM=0212345678                     # 사전등록된 발신번호

# 지입주명 (portal/jiip 의 customer_name)
OWNER_NAME=신동석부장

# 옵션
DRY_RUN=false                              # true 면 실제발송 X, 페이로드만 출력
NOTIFY_OWNER=true                          # true 면 지입주 본인에게도 요약 발송
